rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Photos de passages — accessible uniquement aux utilisateurs connectés
    match /passages/{sessionId}/{fileName} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 2 * 1024 * 1024   // max 2 Mo par fichier
                   && request.resource.contentType.matches('image/jpeg');
    }
  }
}
