rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Photos de passages — lecture ET écriture publiques
    // (l'app peut être utilisée sans connexion Firebase Auth sur certains appareils iOS)
    match /photos/{fileName} {
      allow read:  if true;
      allow write: if request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }
    // Ancien chemin (rétrocompatibilité)
    match /passages/{sessionId}/{fileName} {
      allow read:  if true;
      allow write: if request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }
  }
}
