# Copier ce fichier en .env.local et remplir avec vos valeurs Firebase.
# Obtenir les valeurs depuis : https://console.firebase.google.com → Paramètres du projet.
# ⚠️ Ne jamais commiter .env.local (déjà dans .gitignore).

VITE_FB_API_KEY=your_api_key_here
VITE_FB_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FB_PROJECT_ID=your_project_id
VITE_FB_STORAGE_BUCKET=your_project.firebasestorage.app
VITE_FB_SENDER_ID=your_sender_id
VITE_FB_APP_ID=your_app_id
